# Copy this file to .env and fill in your real values.
# NEVER commit .env to git or share it in chat/screenshots.

# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Any OpenAI chat model works, e.g. gpt-4o-mini, gpt-4o, gpt-4.1
OPENAI_MODEL=gpt-4o-mini

# --- RAG knowledge base (optional but recommended) ---
# The n8n "KB Search API" webhook that returns Purlfrost KB context.
# Leave blank to run without RAG (plain, ungrounded drafts).
KB_SEARCH_URL=https://n8n-jp6p.srv1747149.hstgr.cloud/webhook/kb-search
# Must match the value of the n8n "KB Search Header Auth" credential (header X-KB-Token).
KB_SEARCH_TOKEN=paste-the-same-token-you-set-in-n8n
# Max time to wait for KB retrieval before falling back to an ungrounded draft.
KB_TIMEOUT_MS=8000

PORT=3000

# Optional: path to local HTTPS dev cert (see README for how to generate one)
SSL_CERT_PATH=/home/YOU/.office-addin-dev-certs/localhost.crt
SSL_KEY_PATH=/home/YOU/.office-addin-dev-certs/localhost.key
